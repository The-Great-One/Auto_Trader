# Auto_Trader environment variables
# Copy this to .env and fill in your values.
# NEVER commit .env with real values.

# Oracle server connection (required for dashboards, SSH health checks, paper trading)
AT_SERVER_KEY=~/.ssh/oracle_key        # path to your SSH private key
AT_SERVER_HOST=ubuntu@your.oracle.ip   # user@host for the live trader server
AT_ORACLE=ubuntu@your.oracle.ip         # alias, same as AT_SERVER_HOST
AT_SERVER_REPO=/home/ubuntu/Auto_Trader # repo path on the server

# Telegram paper trading (optional, for live ledger + options paper trader)
AT_TELEGRAM_EXPORT=~/.openclaw/telegram-user/exports/telegram_export_latest.json
AT_TRACKED_CALLS=~/.openclaw/telegram-user/tracked_option_calls.json
AT_WORKSPACE_TOOLS=~/.openclaw/workspace/tools

# Dashboard
DASH_HOST=0.0.0.0
DASH_PORT=8504